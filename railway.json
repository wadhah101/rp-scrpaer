{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "dockerfilePath": "packages/cli/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "rp-to-hevy-cli rp export --type all -o /data/rp/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
