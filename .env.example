# ──────────────────────────────────────────────
# API Credentials (required)
# ──────────────────────────────────────────────

# RP Strength — get from network inspector on https://training.rpstrength.com
RP_BEARER_TOKEN=SECRET

# Hevy — get from https://hevy.com/settings?developer
HEVY_API_KEY=SECRET

# ──────────────────────────────────────────────
# LLM / AI (required for llm-judge & port)
# ──────────────────────────────────────────────

# OpenRouter — used for embeddings and LLM judge
OPENROUTER_API_KEY=SECRET

# Workout title generation (can reuse OpenRouter or any OpenAI-compatible API)
TITLE_API_BASE_URL=https://openrouter.ai/api/v1
TITLE_API_KEY=SECRET
TITLE_API_MODEL=google/gemini-3-flash-preview

# ──────────────────────────────────────────────
# AWS S3 (required for S3 export tasks)
# ──────────────────────────────────────────────

AWS_ACCESS_KEY_ID=SECRET
AWS_SECRET_ACCESS_KEY=SECRET
AWS_REGION=eu-west-1
AWS_ENDPOINT_URL=https://s3.eu-west-1.amazonaws.com
AWS_S3_BUCKET_NAME=rp-to-hevy-data

# ──────────────────────────────────────────────
# Redis (optional, for LLM result caching)
# ──────────────────────────────────────────────

REDIS_URL=redis://127.0.0.1:6379


# ──────────────────────────────────────────────
# Docker / CI (optional, for builds)
# ──────────────────────────────────────────────

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
GITHUB_TOKEN=
