# ──────────────────────────────────────────────
# API Credentials (required)
# ──────────────────────────────────────────────

# RP Strength — get from network inspector on https://training.rpstrength.com
RP_BEARER_TOKEN=SECRET

# Hevy — get from https://hevy.com/settings?developer
HEVY_API_KEY=SECRET

# ──────────────────────────────────────────────
# LLM / AI (OpenAI-compatible APIs)
# ──────────────────────────────────────────────

# Embedding API (required for `embedding embd`)
EMBEDDING_API_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=SECRET
EMBEDDING_API_MODEL=qwen/qwen3-embedding-8b
# EMBEDDING_API_DIMENSIONS=
# EMBEDDING_API_BATCH_SIZE=100

# LLM judge API (required for `embedding llm-judge`)
JUDGE_API_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=SECRET
JUDGE_API_MODEL=google/gemini-3.1-pro-preview

# Workout title generation (required for `port-rp-workout-to-hevy`)
TITLE_API_BASE_URL=https://openrouter.ai/api/v1
TITLE_API_KEY=SECRET
TITLE_API_MODEL=google/gemini-3-flash-preview

# ──────────────────────────────────────────────
# AWS S3 (required for S3 export tasks)
# ──────────────────────────────────────────────

AWS_ACCESS_KEY_ID=SECRET
AWS_SECRET_ACCESS_KEY=SECRET
AWS_REGION=eu-west-1
AWS_ENDPOINT_URL=https://s3.eu-west-1.amazonaws.com
AWS_S3_BUCKET_NAME=rp-to-hevy-data

# ──────────────────────────────────────────────
# ChromaDB (required for embeddings)
# ──────────────────────────────────────────────

CHROMA_HOST=localhost
CHROMA_PORT=8000
# Set CHROMA_API_KEY to use Chroma Cloud instead of a local server
# CHROMA_API_KEY=SECRET

# ──────────────────────────────────────────────
# Turso / libSQL (optional, for LLM result caching)
# ──────────────────────────────────────────────

TURSO_AUTH_TOKEN=SECRET


# ──────────────────────────────────────────────
# Docker / CI (optional, for builds)
# ──────────────────────────────────────────────

REGISTRY_URL=docker.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
