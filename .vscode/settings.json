{
  // Python interpreter from .venv managed by uv
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Disable built-in type checking — ty handles it
  "python.analysis.typeCheckingMode": "off",

  // Ruff as formatter and linter
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // Ruff & ty extensions bundle their own binaries
  // and pick up config from pyproject.toml automatically.

  // Hide noisy dirs in explorer
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.egg-info": true,
    ".ruff_cache": true
  },

  // Search exclusions
  "search.exclude": {
    "**/.venv": true,
    "**/__pycache__": true
  },

  // Match pyproject.toml line-length for Flake8
  "flake8.args": ["--max-line-length=88"],


}
